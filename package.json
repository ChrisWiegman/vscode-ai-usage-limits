{
  "name": "ai-usage-limits",
  "displayName": "AI Usage Limits",
  "description": "Shows Claude and Codex usage budgets in the VS Code status bar using existing extension logins",
  "version": "0.2.1",
  "publisher": "chriswiegman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisWiegman/vscode-ai-usage-limits.git"
  },
  "homepage": "https://github.com/ChrisWiegman/vscode-ai-limits#readme",
  "bugs": {
    "url": "https://github.com/ChrisWiegman/vscode-ai-usage-limits/issues"
  },
  "icon": "assets/icon.png",
  "files": [
    "assets/icon.png",
    "out/src/**/*.js",
    "README.md",
    "LICENSE.txt",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "openai",
    "codex",
    "budget",
    "usage"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-limits.refresh",
        "title": "AI Limits: Refresh Now"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "lint": "biome lint src test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.116.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.0",
    "changie": "^1.24.0",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "diff": "^9.0.0",
    "glob": "^13.0.6",
    "encoding-sniffer": "^1.0.2",
    "serialize-javascript": "^7.0.5"
  }
}
